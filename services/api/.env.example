# Copy to .env for local dev (never commit real values).
NODE_ENV=development
PORT=3000

# Postgres — either DATABASE_URL, or the DB_* parts.
DATABASE_URL=postgres://starshipos_admin:password@localhost:5432/starshipos
# DB_HOST=
# DB_PORT=5432
# DB_USER=starshipos_admin
# DB_PASSWORD=
# DB_NAME=starshipos

# Cognito (from terraform output)
AWS_REGION=eu-west-2
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:5173
