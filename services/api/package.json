{
  "name": "starshipos-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "StarshipOS backend API — replaces Base44 backend functions.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
